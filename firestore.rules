rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public scripts metadata - anyone can read
    match /scripts/{scriptId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Protected script code - only server (Admin SDK) can read, authenticated users can write
    match /script_code/{scriptId} {
      allow read: if false;
      allow write: if request.auth != null;
    }
    // Keys - anyone can read (for validation), authenticated can write
    match /keys/{keyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
